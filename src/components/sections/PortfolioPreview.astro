---
/**
 * PortfolioPreview — Section 03 (Portfolio)
 * Grille bento asymétrique avec rounded-lg,
 * hover overlay avec infos projet (titre, localisation, catégorie),
 * effet translateY(-8px) + shadow au hover
 */
import Section from '@components/ui/Section.astro';
import Container from '@components/ui/Container.astro';
import Button from '@components/ui/Button.astro';
import TextMorph from '@components/react/TextMorph';
import { t, tArray, getLocalizedPath, type Locale } from '@i18n/index';

interface Props { lang?: Locale; }
const lang = Astro.props.lang ?? 'fr';

const comingSoonLabel: Record<string, string> = {
  fr: 'Projet a venir',
  en: 'Coming soon',
  it: 'Prossimamente',
};

const projects = [
  {
    title: 'Villa Azur',
    category: t('portfolio', 'catRenovation', lang),
    location: 'Rayol-Canadel-sur-Mer',
    image: '/images/projets/villa-azur-11.jpeg',
    slug: getLocalizedPath('/projets/villa-azur', lang),
    ready: true,
  },
  {
    title: 'Bormes-les-Mimosas',
    category: t('portfolio', 'catConstruction', lang),
    location: 'Bormes-les-Mimosas',
    image: '/images/projets/bormes-les-mimosas-3.jpg',
    slug: getLocalizedPath('/projets/bormes-les-mimosas', lang),
    ready: true,
  },
  {
    title: 'Villa Aiguebelle',
    category: t('portfolio', 'catRenovation', lang),
    location: 'Aiguebelle, Lavandou',
    image: '/images/projets/aiguebelle-3.jpeg',
    slug: getLocalizedPath('/projets/villa-aiguebelle', lang),
    ready: true,
  },
];
---

<Section background="warm" padding="lg">
  <Container>

    {/* En-tête */}
    <div class="relative mb-16 md:mb-20" data-reveal>
      <span class="section-number-xl">03</span>
      <span class="section-number">{t('portfolio', 'number', lang)}</span>
      <h2 class="editorial-breadcrumb text-section text-primary-dark mt-6 cursor-default">
        <span class="editorial-nav-item font-heading font-light uppercase text-primary-dark/10">{t('portfolio', 'title1', lang)}</span>
        <span class="font-display font-extralight text-primary-dark/15 mx-1 select-none">/</span>
        <TextMorph client:visible words={tArray('portfolio', 'morphWords', lang)} className="editorial-nav-item font-display font-bold uppercase text-primary-dark" />
      </h2>
      <p class="font-body text-lg font-light text-[var(--color-text-light)] mt-4 max-w-xl">
        {t('portfolio', 'subtitle', lang)}
      </p>
    </div>

    {/* Split screen — alternance image / infos */}
    <div class="flex flex-col gap-0" data-mosaic>
      {projects.map((project, i) => {
        const isEven = i % 2 === 0;
        return project.ready ? (
          <a
            href={project.slug}
            data-mosaic-item
            class="group grid grid-cols-1 md:grid-cols-2 min-h-[420px] md:min-h-[520px]"
          >
            {/* Image */}
            <div class:list={['relative overflow-hidden', !isEven && 'md:order-2']}>
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover transition-transform duration-slow ease-smooth group-hover:scale-[1.04]"
                loading="lazy"
              />
            </div>
            {/* Infos */}
            <div class:list={[
              'flex flex-col justify-center px-8 py-12 md:px-16 md:py-20 bg-[var(--color-warm)]',
              !isEven && 'md:order-1',
            ]}>
              <span class="text-[11px] font-heading font-medium text-accent-gold uppercase tracking-[0.25em] mb-4">
                {project.category}
              </span>
              <h3 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-primary-dark mb-4 leading-tight">
                {project.title}
              </h3>
              <span class="text-sm font-heading font-light text-[var(--color-text-light)] tracking-wide">
                {project.location}
              </span>
              <div class="mt-8">
                <span class="inline-flex items-center gap-2 text-xs font-heading font-medium uppercase tracking-[0.15em] text-primary-dark/60 group-hover:text-primary-dark transition-colors duration-base">
                  {lang === 'en' ? 'View project' : 'Voir le projet'}
                  <svg class="w-4 h-4 transition-transform duration-base group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ) : (
          <div
            data-mosaic-item
            class="group grid grid-cols-1 md:grid-cols-2 min-h-[420px] md:min-h-[520px]"
          >
            {/* Image */}
            <div class:list={['relative overflow-hidden', !isEven && 'md:order-2']}>
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover grayscale-[30%] opacity-80"
                loading="lazy"
              />
            </div>
            {/* Infos */}
            <div class:list={[
              'flex flex-col justify-center px-8 py-12 md:px-16 md:py-20 bg-[var(--color-warm)]',
              !isEven && 'md:order-1',
            ]}>
              <span class="text-[11px] font-heading font-medium text-accent-gold/40 uppercase tracking-[0.25em] mb-4">
                {project.category}
              </span>
              <h3 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-primary-dark/50 mb-4 leading-tight">
                {project.title}
              </h3>
              <span class="text-sm font-heading font-light text-[var(--color-text-light)]/40 tracking-wide">
                {project.location}
              </span>
              <div class="mt-8">
                <span class="text-[11px] font-heading font-medium text-primary-dark/30 uppercase tracking-[0.2em]">
                  {comingSoonLabel[lang] || comingSoonLabel.fr}
                </span>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    {/* CTA */}
    <div class="text-center mt-16 md:mt-20">
      <Button href={getLocalizedPath('/projets', lang)} variant="outline" size="lg">
        {t('portfolio', 'cta', lang)}
      </Button>
    </div>

  </Container>
</Section>
